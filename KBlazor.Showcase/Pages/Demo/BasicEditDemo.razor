@* KBlazor.Showcase/Pages/Demo/BasicEditDemo.razor *@
@page "/demo/basicedit"
@inject DataStore Store

<PageTitle>BasicEdit — KBlazor</PageTitle>

<div class="demo-layout">
    <NavMenu />
    <div class="demo-body">
        <div class="demo-header">
            <h2>BasicEdit</h2>
            <p class="demo-sub">Auto-generated forms from [Display] attributes — multi-column layouts and <code>,,</code> cell skipping.</p>
        </div>
        <div class="demo-content">
            <div class="split-demo">
                <div class="order-list">
                    @foreach (var order in Store.Orders.Take(8))
                    {
                        <div class="order-row @(_editing?.Id == order.Id ? "active" : "")"
                             @onclick="() => SelectOrder(order)">
                            <span class="order-name">@order.Name</span>
                            <span class="order-customer">@order.Customer?.Name</span>
                            <span class="status-badge @order.Status.ToString().ToLower()">@order.Status</span>
                        </div>
                    }
                </div>
                <div class="edit-panel">
                    @if (_editing != null)
                    {
                        <div class="toolbar">
                            <div class="toolbar-group">
                                <span class="toolbar-label">COLUMNS</span>
                                @foreach (var n in new[] { 1, 2, 3 })
                                {
                                    <button class="col-btn @(_columns == n ? "active" : "")" @onclick="() => _columns = n">@n</button>
                                }
                            </div>
                            <div class="toolbar-hint">
                                <code>,,</code> in <code>Fields</code> inserts a blank cell — skips a column slot
                            </div>
                        </div>
                        <div class="fields-preview">
                            @foreach (var part in _fields.Split(','))
                            {
                                <span class="field-chip @(part == "" ? "skip-chip" : "")">
                                    @(part == "" ? "skip" : part)
                                </span>
                            }
                        </div>
                        <BasicEdit TItem="PurchaseOrder"
                                   Item="@_editing"
                                   Fields="@_fields"
                                   Save="SaveOrder"
                                   Close="CloseEditor"
                                   Columns="@_columns" />
                    }
                    else
                    {
                        <div class="edit-placeholder">
                            <p>← Select an order to edit</p>
                        </div>
                    }
                </div>
            </div>
        </div>
        <DocPanel ComponentName="BasicEdit"
                  UsageCode="@DocContent.BasicEditUsage"
                  CodeBehind="@DocContent.BasicEditCodeBehind"
                  ModelCode="@DocContent.PurchaseOrderModel"
                  Explanation="@DocContent.BasicEditExplained" />
    </div>
</div>

<style>
    .demo-layout { display: flex; min-height: calc(100vh - 64px); }
    .demo-body { flex: 1; display: flex; flex-direction: column; }
    .demo-header { padding: 32px 32px 16px; border-bottom: 1px solid var(--border); }
    .demo-header h2 { margin: 0 0 8px; font-size: 28px; font-weight: 800; }
    .demo-sub { margin: 0; font-size: 15px; color: var(--text-muted); }
    .demo-content { flex: 1; padding: 24px 32px; }

    .split-demo { display: flex; gap: 24px; min-height: 100%; }
    .order-list { width: 280px; min-width: 280px; display: flex; flex-direction: column; gap: 4px; }
    .order-row { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 8px; cursor: pointer; border: 1px solid var(--border); background: var(--bg-card); }
    .order-row:hover { border-color: var(--accent); }
    .order-row.active { border-color: var(--accent); background: #1E1A3A; }
    .order-name { font-weight: 600; font-size: 13px; flex: 1; }
    .order-customer { font-size: 12px; color: var(--text-muted); flex: 1; }

    .edit-panel { flex: 1; background: var(--bg-card); border-radius: 12px; border: 1px solid var(--border); overflow: hidden; }
    .edit-placeholder { display: flex; align-items: center; justify-content: center; height: 200px; color: var(--text-muted); }

    .toolbar { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; background: #13112A; border-bottom: 1px solid var(--border); gap: 16px; flex-wrap: wrap; }
    .toolbar-group { display: flex; align-items: center; gap: 8px; }
    .toolbar-label { font-size: 10px; font-weight: 700; letter-spacing: 1.5px; color: #4A4868; }
    .col-btn { width: 32px; height: 32px; border-radius: 6px; border: 1px solid var(--border); background: var(--bg-card); color: var(--text-muted); font-size: 13px; font-weight: 600; cursor: pointer; }
    .col-btn:hover { border-color: var(--accent); color: var(--text-primary); }
    .col-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; }
    .toolbar-hint { font-size: 12px; color: var(--text-muted); }
    .toolbar-hint code { background: #0A0918; padding: 1px 5px; border-radius: 4px; color: #B2CCFF; font-size: 11px; }

    .fields-preview { display: flex; flex-wrap: wrap; gap: 6px; padding: 10px 16px; background: #0F0D1E; border-bottom: 1px solid var(--border); }
    .field-chip { font-size: 11px; padding: 2px 8px; border-radius: 999px; background: #1E1A3A; color: var(--text-muted); border: 1px solid var(--border); }
    .skip-chip { background: transparent; color: #4A4868; border-style: dashed; font-style: italic; }

    .status-badge { display: inline-block; padding: 2px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; }
    .status-badge.new { background: #1C1A3A; color: #B2CCFF; }
    .status-badge.pending { background: #2A2414; color: #FFD9B2; }
    .status-badge.inprogress { background: #1A2040; color: #93C5FD; }
    .status-badge.delivered { background: #1E3A2A; color: #A1E5A1; }
    .status-badge.cancelled { background: #3A1A1A; color: #FFBFB2; }
</style>

@code {
    private PurchaseOrder? _editing;
    private int _columns = 2;

    // ,, after Amount inserts a blank cell — Urgent always starts at column 1
    private const string _fields = "Order #,Customer,Status,Order Date,Amount,,Urgent,Delivery Date,Reference,Notes";

    private void SelectOrder(PurchaseOrder order) => _editing = order;

    private void SaveOrder()
    {
        // In-memory: changes are already applied to the object in the DataStore list
        _editing = null;
        StateHasChanged();
    }

    private void CloseEditor()
    {
        _editing = null;
        StateHasChanged();
    }
}

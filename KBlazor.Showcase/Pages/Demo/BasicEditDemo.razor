@* KBlazor.Showcase/Pages/Demo/BasicEditDemo.razor *@
@page "/demo/basicedit"
@inject DataStore Store

<PageTitle>BasicEdit — KBlazor</PageTitle>

<div class="demo-layout">
    <NavMenu />
    <div class="demo-body">
        <div class="demo-header">
            <h2>BasicEdit</h2>
            <p class="demo-sub">Auto-generated forms from [Display] attributes — multi-column layouts and <code>,,</code> cell skipping.</p>
        </div>
        <div class="demo-content">
            <div class="split-demo">
                <div class="order-list">
                    @foreach (var order in Store.Orders.Take(8))
                    {
                        <div class="order-row @(_editing?.Id == order.Id ? "active" : "")"
                             @onclick="() => SelectOrder(order)">
                            <span class="order-name">@order.Name</span>
                            <span class="order-customer">@order.Customer?.Name</span>
                            <span class="status-badge @order.Status.ToString().ToLower()">@order.Status</span>
                        </div>
                    }
                </div>
                <div class="edit-panel">
                    @if (_editing != null)
                    {
                        <div class="toolbar">
                            <div class="toolbar-group">
                                <span class="toolbar-label">COLUMNS</span>
                                @foreach (var n in new[] { 1, 2, 3 })
                                {
                                    <button class="col-btn @(_columns == n ? "active" : "")" @onclick="() => _columns = n">@n</button>
                                }
                            </div>
                            <div class="toolbar-hint">
                                <code>,,</code> in <code>Fields</code> inserts a blank cell — skips a column slot
                            </div>
                        </div>
                        <div class="fields-preview">
                            @foreach (var part in _fields.Split(','))
                            {
                                <span class="field-chip @(part == "" ? "skip-chip" : "")">
                                    @(part == "" ? "skip" : part)
                                </span>
                            }
                        </div>
                        <BasicEdit TItem="PurchaseOrder"
                                   Item="@_editing"
                                   Fields="@_fields"
                                   Save="SaveOrder"
                                   Close="CloseEditor"
                                   Columns="@_columns" />
                    }
                    else
                    {
                        <div class="edit-placeholder">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:0.4;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            <p>Select an order to edit</p>
                        </div>
                    }
                </div>
            </div>
        </div>
        <DocPanel ComponentName="BasicEdit"
                  UsageCode="@DocContent.BasicEditUsage"
                  CodeBehind="@DocContent.BasicEditCodeBehind"
                  ModelCode="@DocContent.PurchaseOrderModel"
                  Explanation="@DocContent.BasicEditExplained" />
    </div>
</div>

<style>
    .split-demo { display: flex; gap: 20px; min-height: 100%; }
    .order-list { width: 280px; min-width: 280px; display: flex; flex-direction: column; gap: 4px; }
    .order-row {
        display: flex; align-items: center; gap: 12px;
        padding: 12px 16px; border-radius: 10px; cursor: pointer;
        border: 1px solid var(--border); background: var(--bg-card);
        transition: all 0.15s ease;
    }
    .order-row:hover { border-color: var(--border-hover); background: rgba(108,92,231,0.04); }
    .order-row.active { border-color: var(--accent); background: rgba(108,92,231,0.08); box-shadow: 0 0 0 1px rgba(108,92,231,0.15); }
    .order-name { font-weight: 600; font-size: 13px; flex: 1; }
    .order-customer { font-size: 12px; color: var(--text-muted); flex: 1; }

    .edit-panel {
        flex: 1; background: var(--bg-card); border-radius: 14px;
        border: 1px solid var(--border); overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    }
    .edit-placeholder {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 8px; height: 200px; color: var(--text-muted); font-size: 14px;
    }

    .toolbar {
        display: flex; align-items: center; justify-content: space-between;
        padding: 12px 16px; background: #0C0B1A;
        border-bottom: 1px solid var(--border); gap: 16px; flex-wrap: wrap;
    }
    .toolbar-group { display: flex; align-items: center; gap: 8px; }
    .toolbar-label { font-size: 10px; font-weight: 700; letter-spacing: 1.5px; color: #4A4868; }
    .col-btn {
        width: 32px; height: 32px; border-radius: 8px;
        border: 1px solid var(--border); background: var(--bg-card);
        color: var(--text-muted); font-size: 13px; font-weight: 600;
        cursor: pointer; transition: all 0.15s ease;
        font-family: 'Inter', sans-serif;
    }
    .col-btn:hover { border-color: var(--accent); color: var(--text-primary); }
    .col-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; box-shadow: 0 2px 8px rgba(108,92,231,0.3); }
    .toolbar-hint { font-size: 12px; color: var(--text-muted); }
    .toolbar-hint code { background: rgba(108,92,231,0.1); padding: 1px 5px; border-radius: 4px; color: #B4A8FF; font-size: 11px; font-family: var(--mono); }

    .fields-preview { display: flex; flex-wrap: wrap; gap: 6px; padding: 10px 16px; background: #0A0918; border-bottom: 1px solid var(--border); }
    .field-chip { font-size: 11px; padding: 2px 10px; border-radius: 999px; background: rgba(108,92,231,0.1); color: var(--text-muted); border: 1px solid rgba(108,92,231,0.15); }
    .skip-chip { background: transparent; color: #4A4868; border-style: dashed; border-color: var(--border); font-style: italic; }
</style>

@code {
    private PurchaseOrder? _editing;
    private int _columns = 2;

    // ,, after Amount inserts a blank cell — Urgent always starts at column 1
    private const string _fields = "Order #,Customer,Status,Order Date,Amount,,Urgent,Delivery Date,Reference,Notes";

    private void SelectOrder(PurchaseOrder order) => _editing = order;

    private void SaveOrder()
    {
        _editing = null;
        StateHasChanged();
    }

    private void CloseEditor()
    {
        _editing = null;
        StateHasChanged();
    }
}

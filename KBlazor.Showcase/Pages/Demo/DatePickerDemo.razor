@* KBlazor.Showcase/Pages/Demo/DatePickerDemo.razor *@
@page "/demo/datepicker"

<PageTitle>RelativeDatePicker — KBlazor</PageTitle>

<div class="demo-layout">
    <NavMenu />
    <div class="demo-body">
        <div class="demo-header">
            <h2>RelativeDatePicker</h2>
            <p class="demo-sub">Supports both absolute date selection and relative expressions like "This Week" or "Last Month".</p>
        </div>
        <div class="demo-content">
            <div class="picker-demo">
                <div class="picker-card">
                    <div class="picker-label">Selected value</div>
                    <RelativeDatePicker @bind-Value="_date"
                                        @bind-StartDate="_start"
                                        @bind-EndDate="_end" />
                    <div class="picker-output">
                        @if (!string.IsNullOrEmpty(_date))
                        {
                            <span>@_date</span>
                        }
                        else
                        {
                            <span style="color:var(--text-muted)">No date selected</span>
                        }
                    </div>

                    @if (_start.HasValue && _end.HasValue)
                    {
                        <div class="picker-label">Resolved date range</div>
                        <div class="resolved-range">
                            <div class="range-row">
                                <span class="range-label">From</span>
                                <span class="range-value">@_start.Value.ToString("ddd, dd MMM yyyy")</span>
                            </div>
                            <div class="range-row">
                                <span class="range-label">To</span>
                                <span class="range-value">@_end.Value.ToString("ddd, dd MMM yyyy HH:mm")</span>
                            </div>
                        </div>
                    }
                </div>

                <div class="examples-card">
                    <div class="example-label">Relative date strings supported by FlexTable filters</div>
                    <div class="examples-grid">
                        @foreach (var example in _examples)
                        {
                            <button class="example-chip @(example == _date ? "active" : "")"
                                    @onclick="() => SelectExample(example)">
                                @example
                            </button>
                        }
                    </div>

                    <div class="calc-label">How it works</div>
                    <div class="calc-flow">
                        <div class="flow-step">
                            <div class="flow-num">1</div>
                            <div class="flow-text"><strong>RelativeDatePicker</strong> builds a string<br /><code>"Last 2 Week"</code></div>
                        </div>
                        <div class="flow-arrow"></div>
                        <div class="flow-step">
                            <div class="flow-num">2</div>
                            <div class="flow-text"><strong>RelativeDateCalc</strong> resolves to dates<br /><code>GetLowerDate() / GetUpperDate()</code></div>
                        </div>
                        <div class="flow-arrow"></div>
                        <div class="flow-step">
                            <div class="flow-num">3</div>
                            <div class="flow-text"><strong>FlexTable</strong> applies as a<br /><code>WHERE date BETWEEN ... AND ...</code></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <DocPanel ComponentName="RelativeDatePicker"
                  UsageCode="@DocContent.DatePickerUsage"
                  CodeBehind="@DocContent.DatePickerCodeBehind"
                  Explanation="@DocContent.DatePickerExplained" />
    </div>
</div>

<style>
    .picker-demo { display: flex; gap: 20px; align-items: flex-start; flex-wrap: wrap; }

    .picker-card {
        background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px;
        padding: 24px; display: flex; flex-direction: column; gap: 16px;
        min-width: 280px; flex: 1; max-width: 400px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    }
    .picker-label { font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.2px; }
    .picker-output { font-size: 14px; color: var(--text-primary); padding: 10px 12px; background: var(--bg-sidebar); border-radius: 8px; border: 1px solid var(--border); }

    .resolved-range { display: flex; flex-direction: column; gap: 8px; animation: fadeIn 0.2s ease; }
    .range-row { display: flex; align-items: center; gap: 12px; padding: 10px 14px; background: #0C0B1A; border-radius: 8px; border: 1px solid var(--border); }
    .range-label { font-size: 10px; font-weight: 700; color: var(--accent); text-transform: uppercase; letter-spacing: 1px; min-width: 40px; }
    .range-value { font-size: 14px; color: var(--text-primary); font-family: var(--mono); }

    .examples-card {
        background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px;
        padding: 24px; display: flex; flex-direction: column; gap: 16px; flex: 1;
        box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    }
    .example-label { font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.2px; }
    .examples-grid { display: flex; flex-wrap: wrap; gap: 8px; }
    .example-chip {
        display: inline-block; background: rgba(108,92,231,0.08); color: #B2CCFF;
        padding: 6px 16px; border-radius: 999px; font-size: 13px; font-weight: 500;
        border: 1px solid rgba(108,92,231,0.15); cursor: pointer;
        transition: all 0.15s ease; font-family: 'Inter', sans-serif;
    }
    .example-chip:hover { border-color: rgba(108,92,231,0.4); color: #fff; background: rgba(108,92,231,0.15); }
    .example-chip.active { background: var(--accent); color: #fff; border-color: var(--accent); box-shadow: 0 2px 10px rgba(108,92,231,0.3); }

    .calc-label { font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.2px; margin-top: 4px; }
    .calc-flow { display: flex; align-items: center; gap: 0; flex-wrap: wrap; }
    .flow-step {
        display: flex; align-items: flex-start; gap: 10px;
        background: #0C0B1A; border: 1px solid var(--border); border-radius: 10px;
        padding: 14px 16px; min-width: 180px;
    }
    .flow-num {
        width: 22px; height: 22px; min-width: 22px; border-radius: 50%;
        background: var(--accent); color: #fff; font-size: 11px; font-weight: 700;
        display: flex; align-items: center; justify-content: center; margin-top: 2px;
        box-shadow: 0 2px 8px rgba(108,92,231,0.3);
    }
    .flow-text { font-size: 12px; color: var(--text-muted); line-height: 1.5; }
    .flow-text strong { color: var(--text-primary); }
    .flow-text code { background: rgba(108,92,231,0.1); padding: 1px 5px; border-radius: 3px; font-size: 11px; color: #B4A8FF; font-family: var(--mono); }
    .flow-arrow { width: 24px; height: 2px; background: var(--accent); position: relative; flex-shrink: 0; opacity: 0.5; }
    .flow-arrow::after { content: ''; position: absolute; right: 0; top: -4px; border: 5px solid transparent; border-left-color: var(--accent); }
</style>

@code {
    private string _date = string.Empty;
    private DateTime? _start;
    private DateTime? _end;

    private void SelectExample(string example)
    {
        _date = example;
        if (KBlazor.Models.RelativeDateCalc.IsValidRelativeDate(_date))
        {
            _start = KBlazor.Models.RelativeDateCalc.GetLowerDate(_date);
            _end = KBlazor.Models.RelativeDateCalc.GetUpperDate(_date);
        }
    }

    private static readonly string[] _examples = new[]
    {
        "Today", "This Week", "This Month", "This Year",
        "Last Week", "Last Month", "Last Year",
        "Next Week", "Next Month", "Next Year"
    };
}

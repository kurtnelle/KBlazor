@* KBlazor.Showcase/Pages/Demo/ChipsDemo.razor *@
@page "/demo/chips"
@inject DataStore Store

<PageTitle>Card View — KBlazor</PageTitle>

<div class="demo-layout">
    <NavMenu />
    <div class="demo-body">
        <div class="demo-header">
            <h2>Card View</h2>
            <p class="demo-sub">FlexTable in Card mode — render items as clickable chips with colour-coding.</p>
        </div>
        <div class="demo-content">
            <MudPaper Elevation="0" Class="table-paper" Style="padding:12px;">
                <FlexTable TItem="PurchaseOrder"
                           Items="@_orders"
                           Fields="Order #,Customer,Status,Amount"
                           DefaultViewMode="FlexTableViewMode.Chips"
                           ChipDisplayField="Name"
                           ChipColor="@GetChipColor"
                           SelectionChanged="OnChipClicked" />
            </MudPaper>

            @if (_selected is not null)
            {
                <div class="selected-card">
                    <div class="selected-label">Selected Order</div>
                    <div class="selected-row"><span class="field-name">Order #</span> <span>@_selected.Name</span></div>
                    <div class="selected-row"><span class="field-name">Customer</span> <span>@_selected.CustomerName</span></div>
                    <div class="selected-row"><span class="field-name">Status</span> <span class="status-badge @_selected.Status.ToString().ToLower()">@_selected.Status</span></div>
                    <div class="selected-row"><span class="field-name">Amount</span> <span style="font-family:var(--mono);">$@_selected.Amount.ToString("N2")</span></div>
                </div>
            }
        </div>
        <DocPanel ComponentName="FlexTable (Card View)"
                  UsageCode="@DocContent.ChipsUsage"
                  CodeBehind="@DocContent.ChipsCodeBehind"
                  ModelCode="@DocContent.PurchaseOrderModel"
                  Explanation="@DocContent.ChipsExplained" />
    </div>
</div>

<style>
    .selected-card {
        background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px;
        padding: 22px; display: flex; flex-direction: column; gap: 12px; max-width: 400px;
        animation: fadeIn 0.2s ease;
        box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    }
    .selected-label { font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.2px; }
    .selected-row { display: flex; align-items: center; gap: 12px; font-size: 14px; color: var(--text-primary); }
    .field-name { color: var(--text-muted); min-width: 80px; font-weight: 600; font-size: 12px; }
</style>

@code {
    private IQueryable<PurchaseOrder> _orders = default!;
    private PurchaseOrder? _selected;

    protected override void OnInitialized()
        => _orders = Store.Orders.AsQueryable();

    private MudBlazor.Color GetChipColor(PurchaseOrder order)
        => order.Status switch
        {
            OrderStatus.New        => MudBlazor.Color.Default,
            OrderStatus.Pending    => MudBlazor.Color.Warning,
            OrderStatus.InProgress => MudBlazor.Color.Info,
            OrderStatus.Delivered  => MudBlazor.Color.Success,
            OrderStatus.Cancelled  => MudBlazor.Color.Error,
            _                      => MudBlazor.Color.Default,
        };

    private void OnChipClicked(PurchaseOrder order, string command)
    {
        _selected = order;
    }
}

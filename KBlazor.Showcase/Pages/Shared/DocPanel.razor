@* KBlazor.Showcase/Pages/Shared/DocPanel.razor *@
@inject IJSRuntime JS

<div class="doc-panel">
    <div class="doc-toolbar">
        <button class="doc-btn @(_showCode ? "doc-btn--active" : "")" @onclick="ToggleCode">
            @if (_showCode)
            {
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                <span>Hide Code</span>
            }
            else
            {
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                <span>Show Code</span>
            }
        </button>
    </div>

    @if (_showCode)
    {
        <div class="doc-code-area">
            @if (!string.IsNullOrEmpty(Explanation))
            {
                <div class="doc-explain">
                    <p>@((MarkupString)Explanation)</p>
                </div>
            }
            <div class="doc-tabs">
                <button class="doc-tab @(_activeTab == "razor" ? "doc-tab--active" : "")" @onclick='() => SwitchTab("razor")'>Razor</button>
                @if (!string.IsNullOrEmpty(CodeBehind))
                {
                    <button class="doc-tab @(_activeTab == "cs" ? "doc-tab--active" : "")" @onclick='() => SwitchTab("cs")'>C#</button>
                }
                @if (!string.IsNullOrEmpty(ModelCode))
                {
                    <button class="doc-tab @(_activeTab == "model" ? "doc-tab--active" : "")" @onclick='() => SwitchTab("model")'>Model</button>
                }
            </div>
            <div class="doc-code-block">
                @if (_activeTab == "razor")
                {
                    <pre class="doc-code"><code class="language-xml">@UsageCode.Trim()</code></pre>
                }
                else if (_activeTab == "cs" && !string.IsNullOrEmpty(CodeBehind))
                {
                    <pre class="doc-code"><code class="language-csharp">@CodeBehind.Trim()</code></pre>
                }
                else if (_activeTab == "model" && !string.IsNullOrEmpty(ModelCode))
                {
                    <pre class="doc-code"><code class="language-csharp">@ModelCode.Trim()</code></pre>
                }
            </div>
        </div>
    }
</div>

<style>
    .doc-panel {
        border-top: 1px solid var(--border);
        background: var(--bg-sidebar);
        max-width: 100%;
        overflow: hidden;
    }

    /* ── Toolbar ── */
    .doc-toolbar {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px 24px;
    }
    .doc-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 24px;
        height: 40px;
        background: rgba(108,92,231,0.06);
        border: 1px solid rgba(108,92,231,0.2);
        border-radius: 10px;
        color: var(--accent);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        font-family: 'Inter', sans-serif;
    }
    .doc-btn:hover {
        color: #fff;
        border-color: rgba(108,92,231,0.5);
        background: rgba(108,92,231,0.12);
        box-shadow: 0 2px 12px rgba(108,92,231,0.15);
    }
    .doc-btn--active {
        background: rgba(108,92,231,0.12);
        border-color: rgba(108,92,231,0.35);
    }

    /* ── Code area ── */
    .doc-code-area {
        padding: 0 24px 24px;
        display: flex;
        flex-direction: column;
        gap: 0;
        animation: fadeIn 0.25s ease;
        max-width: 100%;
        overflow: hidden;
    }
    .doc-explain {
        background: rgba(108,92,231,0.06);
        border-left: 3px solid var(--accent);
        border-radius: 0 10px 10px 0;
        padding: 14px 18px;
        margin-bottom: 16px;
    }
    .doc-explain p {
        font-size: 14px;
        color: var(--text-muted);
        line-height: 1.7;
        margin: 0;
    }
    .doc-explain code {
        background: rgba(108,92,231,0.1);
        border-radius: 4px;
        padding: 1px 6px;
        font-size: 12px;
        color: #B4A8FF;
        font-family: var(--mono);
    }

    /* ── Tabs ── */
    .doc-tabs {
        display: flex; gap: 0;
        background: #0C0B1A;
        border-radius: 10px 10px 0 0;
        border: 1px solid var(--border);
        border-bottom: none;
        overflow: hidden;
    }
    .doc-tab {
        padding: 10px 20px;
        font-size: 12px; font-weight: 600;
        letter-spacing: 0.3px;
        color: var(--text-muted);
        background: transparent;
        border: none; border-right: 1px solid var(--border);
        cursor: pointer;
        transition: all 0.15s ease;
        font-family: 'Inter', sans-serif;
        text-transform: uppercase;
    }
    .doc-tab:last-child { border-right: none; }
    .doc-tab:hover { color: var(--text-primary); background: rgba(108,92,231,0.06); }
    .doc-tab--active {
        color: var(--accent) !important;
        background: rgba(108,92,231,0.08) !important;
        box-shadow: inset 0 -2px 0 var(--accent);
    }

    .doc-code-block {
        border-radius: 0 0 10px 10px;
        overflow: hidden;
        border: 1px solid var(--border);
        border-top: 1px solid var(--border);
        max-width: 100%;
    }
    .doc-code {
        margin: 0;
        padding: 0;
        border-radius: 0;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    /* Override highlight.js theme background */
    .doc-code code.hljs,
    .doc-code code {
        background: #0A0918 !important;
        padding: 18px 20px !important;
        font-family: var(--mono) !important;
        font-size: 13px !important;
        line-height: 1.8 !important;
        border-radius: 0 !important;
        white-space: pre;
        word-wrap: normal;
        overflow-x: auto;
    }
</style>

@code {
    [Parameter, EditorRequired] public string ComponentName { get; set; } = "";
    [Parameter, EditorRequired] public string UsageCode { get; set; } = "";
    [Parameter, EditorRequired] public string Explanation { get; set; } = "";
    [Parameter] public string CodeBehind { get; set; } = "";
    [Parameter] public string ModelCode { get; set; } = "";

    private bool _showCode = false;
    private string _activeTab = "razor";

    private async Task ToggleCode()
    {
        _showCode = !_showCode;
        if (_showCode)
        {
            _activeTab = "razor";
            await HighlightAsync();
        }
    }

    private async Task SwitchTab(string tab)
    {
        _activeTab = tab;
        await HighlightAsync();
    }

    private async Task HighlightAsync()
    {
        await Task.Yield();
        StateHasChanged();
        await Task.Delay(50);
        await JS.InvokeVoidAsync("highlightAllCode");
    }
}

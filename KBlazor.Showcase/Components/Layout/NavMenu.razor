@* KBlazor.Showcase/Components/Layout/NavMenu.razor *@
<nav class="demo-sidebar">
    <div class="sidebar-section-title">OVERVIEW</div>
    <NavLink href="/getting-started" Match="NavLinkMatch.All" class="sidebar-item">
        <span class="sidebar-indicator"></span> Getting Started
    </NavLink>

    <div class="sidebar-section-title" style="margin-top:18px;">COMPONENTS</div>

    <div class="sidebar-parent">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
        FlexTable
    </div>
    <NavLink href="/demo/flextable" Match="NavLinkMatch.All" class="sidebar-item sidebar-sub">
        <span class="sidebar-indicator"></span> Table View
    </NavLink>
    <NavLink href="/demo/chips" Match="NavLinkMatch.All" class="sidebar-item sidebar-sub">
        <span class="sidebar-indicator"></span> Card View
    </NavLink>
    <NavLink href="/demo/kanban" Match="NavLinkMatch.All" class="sidebar-item sidebar-sub">
        <span class="sidebar-indicator"></span> Kanban View
    </NavLink>

    <NavLink href="/demo/basicedit" Match="NavLinkMatch.All" class="sidebar-item">
        <span class="sidebar-indicator"></span> BasicEdit
    </NavLink>
    <NavLink href="/demo/cyclestate" Match="NavLinkMatch.All" class="sidebar-item">
        <span class="sidebar-indicator"></span> CycleStateButton
    </NavLink>
    <NavLink href="/demo/datepicker" Match="NavLinkMatch.All" class="sidebar-item">
        <span class="sidebar-indicator"></span> RelativeDatePicker
    </NavLink>

    <div class="sidebar-section-title" style="margin-top:18px;">REFERENCE</div>
    <NavLink href="/demo/attributes" Match="NavLinkMatch.All" class="sidebar-item">
        <span class="sidebar-indicator"></span> Attributes
    </NavLink>
</nav>

<style>
    .demo-sidebar {
        width: 220px; min-width: 220px;
        background: var(--bg-sidebar);
        padding: 20px 0;
        display: flex; flex-direction: column; gap: 1px;
        border-right: 1px solid var(--border);
        align-self: stretch;
    }
    .sidebar-section-title {
        font-size: 10px; font-weight: 700; letter-spacing: 1.8px;
        color: #4A4868; padding: 0 20px 8px;
    }
    .sidebar-item {
        display: flex; align-items: center; gap: 10px;
        height: 36px; padding: 0 20px;
        font-size: 13px; color: var(--text-muted);
        text-decoration: none !important; border-radius: 0;
        margin: 0 8px; border-radius: 8px;
        transition: all 0.15s ease;
    }
    .sidebar-item:hover {
        color: var(--text-primary);
        background: rgba(108,92,231,0.08);
    }
    .sidebar-item.active {
        color: var(--text-primary);
        background: rgba(108,92,231,0.12);
        font-weight: 600;
    }
    .sidebar-item.active .sidebar-indicator {
        display: block; width: 3px; height: 20px;
        background: var(--accent); border-radius: 2px;
        box-shadow: 0 0 8px var(--accent-glow);
    }
    .sidebar-indicator { display: block; width: 3px; height: 20px; }

    .sidebar-parent {
        display: flex; align-items: center; gap: 8px;
        font-size: 13px; font-weight: 600; color: var(--text-primary);
        padding: 8px 20px; margin: 2px 8px; border-radius: 8px;
    }
    .sidebar-parent svg { color: var(--accent); opacity: 0.7; }
    .sidebar-sub {
        padding-left: 42px !important;
        font-size: 12px !important;
        height: 32px !important;
        color: var(--text-muted) !important;
    }
    .sidebar-sub:hover { color: var(--text-primary) !important; }
    .sidebar-sub.active { color: var(--text-primary) !important; }
</style>

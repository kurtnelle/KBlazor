    </NavLink>
    <div class="sidebar-section-title" style="margin-top:16px;">COMPONENTS</div>
    <NavLink href="/demo/flextable" Match="NavLinkMatch.All" class="sidebar-item">
        <span class="sidebar-indicator"></span> FlexTable
